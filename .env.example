# ============================================
# Agent Skills — Environment Variables
# ============================================
# Copy to .env and fill in your values.
# Never commit .env to git!

# --- Core (required) ---
GITHUB_TOKEN=              # GitHub PAT with repo scope — for pushing skills
SKILLS_REPO_OWNER=xyz # GitHub org/user owning the agent-skills repo
SKILLS_REPO_NAME=agent-skills # Repository name

# --- Jira (for jira-watcher skill) ---
JIRA_API_TOKEN=            # Jira API token (admin@ruh.ai)
JIRA_BASE_URL=https://abc.atlassian.net
JIRA_USER=
JIRA_AUTH_USER=

# --- Add more env vars as skills require them ---
# Each skill declares its env requirements in metadata.openclaw.requires.env
# Run: python3 meta/skill-creator/scripts/validate_skill.py to check
